generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Category {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  parentId    Int?
  parent      Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([name, parentId])
}

model Product {
  id             Int      @id @default(autoincrement())
  name           String
  description    String   @db.Text
  type           String   @default("CARD")
  
  // Base details
  compareAtPrice Float?
  imageUrl       String?
  additionalImages String[] @default([])
  
  // Categorization
  categoryId     Int?
  category       Category? @relation(fields: [categoryId], references: [id])
  
  // Card-specific details
  cardName       String?
  cardSeries     String?
  isRookie       Boolean  @default(false)
  isAutograph    Boolean  @default(false)
  isNumbered     Boolean  @default(false)
  serialNumber   String?  // e.g. "10/99"
  isParallel     Boolean  @default(false)
  
  // Other flags
  isPreorder     Boolean  @default(false)
  isFeatured     Boolean  @default(false)

  variations     ProductVariation[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  wishlistItems  WishlistItem[]
}

model ProductVariation {
  id             Int      @id @default(autoincrement())
  productId      Int
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  condition      String   @default("N/A")
  isGraded       Boolean  @default(false)
  gradingCompany String?
  grade          String?
  
  price          Float
  stock          Int      @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cartItems      CartItem[]
  orderItems     OrderItem[]
  reservations   StockReservation[]
}

model CartItem {
  id                 Int      @id @default(autoincrement())
  userId             Int
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productVariationId Int?
  productVariation   ProductVariation? @relation(fields: [productVariationId], references: [id], onDelete: Cascade)
  quantity           Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model StockReservation {
  id                 Int      @id @default(autoincrement())
  productVariationId Int
  productVariation   ProductVariation @relation(fields: [productVariationId], references: [id], onDelete: Cascade)
  quantity           Int
  expiresAt          DateTime
  userId             Int?     // If tied to a logged-in user
  sessionId          String?  // If tied to an anonymous user session
  createdAt          DateTime @default(now())
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  address      String?
  city         String?
  state        String?
  zip          String?
  country      String?
  role               String               @default("CUSTOMER") // CUSTOMER, ADMIN
  storeCredit        Float                @default(0)
  orders             Order[]
  wishlistItems WishlistItem[]
  buyListSubmissions BuyListSubmission[]
  cartItems    CartItem[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Order {
  id            Int         @id @default(autoincrement())
  userId        Int?
  user          User?       @relation(fields: [userId], references: [id])
  customerName  String
  email         String
  address       String
  city          String
  state         String
  zip           String
  country       String?
  totalAmount   Float
  taxAmount     Float    @default(0)
  taxRate       Float    @default(0) // Stored as decimal (e.g. 0.13 for 13%)
  status        String      @default("PENDING") // PENDING, PAID, SHIPPED
  paypalOrderId String?
  trackingNumber String?
  shippingCarrier String?
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id                 Int      @id @default(autoincrement())
  orderId            Int
  order              Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariationId Int?
  productVariation   ProductVariation? @relation(fields: [productVariationId], references: [id], onDelete: Restrict)
  quantity           Int
  price              Float    // Price at the time of purchase
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  status    String   @default("OPEN") // OPEN, RESOLVED
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  replies   TicketReply[]
}

model TicketReply {
  id        Int      @id @default(autoincrement())
  messageId Int
  message   ContactMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  body      String
  isAdmin   Boolean  @default(true)
  createdAt DateTime @default(now())
}

model WaitlistSubscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}

model StoreSettings {
  id           Int      @id @default(1)
  taxEnabled   Boolean  @default(false)
  updatedAt    DateTime @updatedAt
}

model WishlistItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model BuyListSubmission {
  id           Int           @id @default(autoincrement())
  userId       Int
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       String        @default("PENDING") // PENDING, REVIEWING, OFFER_MADE, ACCEPTED, REJECTED, COMPLETED
  totalOffered Float?
  cashOffer    Float?
  creditOffer  Float?
  payoutMethod String?       // "PAYPAL" or "STORE_CREDIT"
  paypalEmail  String?
  notes        String?
  items        BuyListItem[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model BuyListItem {
  id             Int               @id @default(autoincrement())
  submissionId   Int
  submission     BuyListSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  cardName       String
  cardSeries     String?
  condition      String
  isGraded       Boolean           @default(false)
  gradingCompany String?
  grade          String?
  quantity       Int               @default(1)
  expectedPrice  Float?            // What the user hopes to get
  offeredPrice   Float?            // What the admin offers
  status         String            @default("PENDING") // PENDING, ACCEPTED, REJECTED
  imageUrl       String?           // Image uploaded by user
}
