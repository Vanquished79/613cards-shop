generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Category {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  parentId    Int?
  parent      Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([name, parentId])
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price          Float
  compareAtPrice Float?
  stock          Int      @default(0)
  imageUrl    String?
  additionalImages String[] @default([])
  condition   String?
  isFeatured  Boolean  @default(false)
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
  
  type        String   @default("CARD") // CARD, BOX, or SUPPLY

  // Card-specific fields
  cardName    String?
  cardSeries  String?
  cardBrand   String?
  isRookie    Boolean  @default(false)
  isAutograph Boolean  @default(false)
  isNumbered  Boolean  @default(false)
  serialNumber String? // e.g. "245/499"
  isParallel  Boolean  @default(false)

  // Expansion Phase 1 fields
  isPreorder  Boolean  @default(false)
  releaseDate DateTime?
  isGraded    Boolean  @default(false)
  gradingCompany String?
  grade       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]
  reservations CartReservation[]
  wishlistItems WishlistItem[]
}

model CartReservation {
  id        Int      @id @default(autoincrement())
  sessionId String
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([productId])
  @@index([expiresAt])
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  address      String?
  city         String?
  state        String?
  zip          String?
  role         String   @default("CUSTOMER") // CUSTOMER, ADMIN
  orders       Order[]
  wishlistItems WishlistItem[]
  buyListSubmissions BuyListSubmission[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Order {
  id            Int         @id @default(autoincrement())
  userId        Int?
  user          User?       @relation(fields: [userId], references: [id])
  customerName  String
  email         String
  address       String
  city          String
  state         String
  zip           String
  country       String?
  totalAmount   Float
  taxAmount     Float    @default(0)
  taxRate       Float    @default(0) // Stored as decimal (e.g. 0.13 for 13%)
  status        String      @default("PENDING") // PENDING, PAID, SHIPPED
  paypalOrderId String?
  trackingNumber String?
  shippingCarrier String?
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int
  price     Float    // Price at the time of purchase
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  status    String   @default("OPEN") // OPEN, RESOLVED
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  replies   TicketReply[]
}

model TicketReply {
  id        Int      @id @default(autoincrement())
  messageId Int
  message   ContactMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  body      String
  isAdmin   Boolean  @default(true)
  createdAt DateTime @default(now())
}

model WaitlistSubscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}

model StoreSettings {
  id           Int      @id @default(1)
  taxEnabled   Boolean  @default(false)
  updatedAt    DateTime @updatedAt
}

model WishlistItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model BuyListSubmission {
  id           Int           @id @default(autoincrement())
  userId       Int
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       String        @default("PENDING") // PENDING, REVIEWING, APPROVED, REJECTED, COMPLETED
  totalOffered Float?
  notes        String?
  items        BuyListItem[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model BuyListItem {
  id             Int               @id @default(autoincrement())
  submissionId   Int
  submission     BuyListSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  cardName       String
  cardSeries     String?
  condition      String
  isGraded       Boolean           @default(false)
  gradingCompany String?
  grade          String?
  quantity       Int               @default(1)
  expectedPrice  Float?            // What the user hopes to get
  offeredPrice   Float?            // What the admin offers
  status         String            @default("PENDING") // PENDING, ACCEPTED, REJECTED
}
